# pnpm settings.
#
# `auto-install-peers` keeps React peer deps from triggering warning spam on
# every install. Default in pnpm v8+ but explicit is safer.
auto-install-peers=true

# `strict-peer-dependencies=false` lets us proceed when a transitive dep
# requests a peer we don't have. Tailwind v4 and Plotly each pull in graphs
# with occasional peer mismatches that are benign.
strict-peer-dependencies=false
